---
interface Props {
  currentPage: "work" | "about";
}

const { currentPage } = Astro.props;
---

<header
  class="site-header site-header--work mb-12 flex flex-col gap-4 md:mb-16 md:flex-row md:items-baseline md:justify-between md:gap-10"
>
  <a
    href="/"
    class="text-[1.375rem] font-bold leading-none tracking-tight text-ink md:text-[1.75rem]"
    >Alec Donovan Illustration</a
  >
  <nav class="flex flex-wrap items-center gap-6 md:gap-8">
    <a
      href="/"
      class:list={[
        "site-nav-work text-[0.9375rem] font-normal leading-none text-ink",
        currentPage === "work"
          ? "border-b border-ink pb-0.5"
          : "decoration-transparent",
      ]}
      aria-current={currentPage === "work" ? "page" : undefined}
      >Work</a
    >
    <a
      href="/about"
      class:list={[
        "text-[0.9375rem] font-normal leading-none text-ink",
        currentPage === "about"
          ? "border-b border-ink pb-0.5"
          : "decoration-transparent",
      ]}
      aria-current={currentPage === "about" ? "page" : undefined}
      >About</a
    >
  </nav>
</header>
