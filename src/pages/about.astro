---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import aboutData from "../data/about.json";

const links = aboutData.links ?? [];
---

<Layout title="Alec Donovan•About">
  <div class="min-h-screen bg-lime text-ink">
    <div
      class="mx-auto max-w-[1600px] px-5 pb-16 pt-8 md:px-10 md:pt-12 lg:px-14"
    >
      <Header currentPage="about" />

      <main>
        <p
          class="text-[2.65rem] font-bold leading-[0.98] tracking-tight md:text-[3.9rem] lg:text-[4.35rem]"
        >
          {aboutData.bio}
          <a
            href={`mailto:${aboutData.email}`}
            class="underline decoration-[3px] underline-offset-4"
          >
            this email address.
          </a>
        </p>

        {links.length > 0 && (
          <div class="mt-12 flex flex-wrap gap-x-10 gap-y-3">
            {links.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener"
                class="inline-block text-[1.05rem] font-normal underline decoration-[1px] underline-offset-4"
              >
                &rarr; {link.text}
              </a>
            ))}
          </div>
        )}
      </main>
    </div>
  </div>
</Layout>
