---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import { gridThumbSrc, workItems } from "../data/work";

/** First N cards: eager thumbs + immediate grid video start (top of masonry / mobile stack). */
const EAGER_THUMB_COUNT = 9;
/** First N get fetchpriority=high on the visible thumb (browser budget ~few highs per page). */
const HIGH_FETCH_THUMB_COUNT = 3;
/** Preload hints in <head> for the first visible row (deduped in Layout). */
const preloadThumbUrls = workItems
  .slice(0, HIGH_FETCH_THUMB_COUNT)
  .map((item) => gridThumbSrc(item.slides[0]));

const lightboxProjects = workItems.map((item) => ({
  projectTitle: item.title,
  projectDescription: item.description,
  slides: item.slides,
}));

const carouselProjects = workItems.map((item) => ({
  thumbs: item.slides.map((s) => gridThumbSrc(s)),
}));
---

<Layout title="Alec Donovan•Work" preloadImages={preloadThumbUrls}>
  <div
    class="mx-auto max-w-[1600px] px-5 pb-20 pt-8 md:px-10 md:pb-24 md:pt-12 lg:px-14"
  >
    <Header currentPage="work" />

    <main
      id="work-grid"
      class="grid grid-cols-1 gap-0 md:grid-cols-3 md:gap-x-8 md:items-start"
      aria-label="Selected work"
    >
      {
        workItems.map((item, projectIndex) => {
          const thumbs = item.slides.map((s) => gridThumbSrc(s));
          const total = item.slides.length;
          const multi = total > 1;
          const first = item.slides[0];
          const isVideo = first.kind === "video";
          const videoSrc = isVideo ? (first as any).src : "";
          const videoPoster = isVideo ? (first as any).poster : "";
          const videoAutoplay = isVideo && (first as any).autoplay !== false;
          const firstThumbUrl = thumbs[0] ?? "";
          const firstThumbIsGif = firstThumbUrl.toLowerCase().endsWith(".gif");
          const thumbEager =
            projectIndex < EAGER_THUMB_COUNT || firstThumbIsGif;
          const thumbFetchPriority =
            projectIndex < HIGH_FETCH_THUMB_COUNT ? "high" : undefined;

          return (
            <article
              class="work-card w-full"
              data-project-index={String(projectIndex)}
              data-carousel-index="0"
            >
              <!-- Native <button> breaks touch-drag on iOS; use div + role for the thumb hit area. -->
              <div
                role="button"
                tabindex="0"
                data-pswp-project={String(projectIndex)}
                aria-label={`Open ${item.title} gallery`}
                class="block w-full cursor-pointer text-left focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-ink"
              >
                <div
                  class="relative overflow-hidden rounded-2xl bg-ink/5 md:rounded-[10px]"
                  style={`aspect-ratio: ${first.width} / ${first.height};`}
                  data-carousel-frame
                >
                  <div
                    class="work-thumb-skeleton"
                    data-work-thumb-skeleton
                    aria-hidden="true"
                  />
                  {isVideo && videoAutoplay ? (
                    <video
                      class="absolute inset-0 z-[2] w-full h-full object-cover object-left-top work-thumb-media"
                      data-project-thumb
                      muted
                      loop
                      playsinline
                      preload={projectIndex < EAGER_THUMB_COUNT
                        ? "metadata"
                        : "none"}
                      data-grid-video-src={videoSrc}
                      {...(projectIndex < EAGER_THUMB_COUNT
                        ? { "data-grid-video-priority": "" }
                        : {})}
                      poster={thumbs[0]}
                      {...(thumbFetchPriority
                        ? { fetchpriority: thumbFetchPriority }
                        : {})}
                    />
                  ) : isVideo ? (
                    <img
                      class="absolute inset-0 z-[2] w-full h-full object-cover object-left-top work-thumb-media"
                      data-project-thumb
                      draggable="false"
                      src={thumbs[0]}
                      alt={item.thumbAlt}
                      loading={thumbEager ? "eager" : "lazy"}
                      decoding="async"
                      {...(thumbFetchPriority
                        ? { fetchpriority: thumbFetchPriority }
                        : {})}
                    />
                  ) : (
                    <img
                      class="absolute inset-0 z-[2] w-full h-full object-cover object-left-top work-thumb-media"
                      data-project-thumb
                      draggable="false"
                      src={thumbs[0]}
                      alt={item.thumbAlt}
                      loading={thumbEager ? "eager" : "lazy"}
                      decoding="async"
                      {...(thumbFetchPriority
                        ? { fetchpriority: thumbFetchPriority }
                        : {})}
                    />
                  )}
                </div>
              </div>
              <div class="mt-3 flex items-center justify-between gap-4 pb-[20px]">
                <button
                  type="button"
                  data-pswp-project={String(projectIndex)}
                  aria-label={`Open ${item.title} gallery`}
                  class="min-w-0 flex-1 cursor-pointer text-left text-[0.9375rem] font-normal leading-tight text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-ink"
                >
                  {item.title}
                </button>
                {multi ? (
                  <div
                    class="flex shrink-0 items-center rounded-full bg-lime text-[0.75rem] font-semibold leading-none tracking-wide text-ink"
                    data-carousel-controls
                  >
                    <button
                      type="button"
                      data-carousel-prev
                      class="flex cursor-pointer items-center py-1 pl-2 pr-0.5"
                      aria-label={`Previous ${item.title} slide`}
                    >
                      <span class="material-symbols-outlined" style="font-size: 14px; font-variation-settings: 'opsz' 20;">arrow_back_ios_new</span>
                    </button>
                    <span class="whitespace-nowrap py-1">
                      <span data-carousel-current>1</span>/{total}
                    </span>
                    <button
                      type="button"
                      data-carousel-next
                      class="flex cursor-pointer items-center py-1 pl-0.5 pr-2"
                      aria-label={`Next ${item.title} slide`}
                    >
                      <span class="material-symbols-outlined" style="font-size: 14px; font-variation-settings: 'opsz' 20;">arrow_forward_ios</span>
                    </button>
                  </div>
                ) : null}
              </div>
            </article>
          );
        })
      }
    </main>
  </div>

  <div
    id="lightbox"
    class="fixed inset-0 z-[9000] flex flex-col bg-ink pt-[7.5rem] md:pt-[6.5rem]"
    aria-modal="true"
    role="dialog"
    aria-label="Project gallery"
  >
    <div class="shrink-0 flex items-center justify-between px-5 pb-2.5 md:pb-0 md:px-10 lg:px-14">
      <button
        id="lightbox-close"
        type="button"
        class="flex cursor-pointer items-center text-lime"
        aria-label="Close gallery"
      >
        <span class="material-symbols-outlined" style="font-size: 36px; font-variation-settings: 'opsz' 48;">close</span>
      </button>
      <div class="flex items-center gap-4">
        <button
          id="lightbox-prev"
          type="button"
          class="flex cursor-pointer items-center text-lime"
          aria-label="Previous project"
        >
          <span class="material-symbols-outlined" style="font-size: 36px; font-variation-settings: 'opsz' 48;">arrow_back</span>
        </button>
        <button
          id="lightbox-next"
          type="button"
          class="flex cursor-pointer items-center text-lime"
          aria-label="Next project"
        >
          <span class="material-symbols-outlined" style="font-size: 36px; font-variation-settings: 'opsz' 48;">arrow_forward</span>
        </button>
      </div>
    </div>

    <div id="lightbox-body" class="lightbox-body flex-1 min-h-0 flex flex-col">
      <div id="lightbox-caption" class="lightbox-caption shrink-0 px-5 pt-4 pb-2 md:order-1 md:px-10 md:pt-6 md:pb-10 lg:px-14">
        <h2
          id="lightbox-title"
          class="text-[clamp(1.125rem,2.5vw,1.5rem)] font-bold leading-tight text-white"
        ></h2>
        <p
          id="lightbox-desc"
          class="mt-2 max-w-[42rem] text-[0.9375rem] font-normal leading-relaxed text-white/95"
        ></p>
      </div>

      <div
        id="lightbox-scroll"
        class="lightbox-scroll flex-1 min-h-0 mt-2 md:mt-5"
      >
        <div id="lightbox-slides" class="lightbox-slides flex gap-3 md:gap-4"></div>
      </div>
    </div>
  </div>

  <style>
    #work-grid:not(.masonry-ready) {
      opacity: 0;
    }
    #work-grid.masonry-ready {
      opacity: 1;
      transition: opacity 0.15s ease;
    }
  </style>

  <script is:inline define:vars={{ lightboxProjects, carouselProjects }}>
    window.__WORK_LIGHTBOX_PROJECTS__ = lightboxProjects;
    window.__WORK_CAROUSEL_PROJECTS__ = carouselProjects;
  </script>
  <script>
    import "../scripts/masonry";
    import "../scripts/lightbox";
  </script>
</Layout>
